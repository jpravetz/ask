{
  "name": "@jpravetz/ask",
  "version": "2.0.9",
  "exports": {
    ".": "./src/mod.ts"
  },
  "publish": {
    "include": [
      "./src"
    ]
  },
  "tasks": {
    "fmt": "deno fmt src test *.json",
    "lint": "deno lint src test *.ts *.json",
    "check": "deno check src examples",
    "test:interactive": "deno run -A ./examples/test.ts",
    "test": "deno test -A ./test/dummy.test.ts",
    "docs": "deno doc --json src/mod.ts 2> /dev/null | cat > library-docs.json",
    "ok": "deno fmt && deno task lint && deno task check && deno task test && deno task docs",
    "dev": "deno run --watch main.ts"
  },
  "fmt": {
    "singleQuote": true,
    "lineWidth": 110,
    "include": [
      "src",
      "examples",
      "launch.config.json",
      "mod.ts"
    ]
  },
  "lint": {
    "include": [
      "src",
      "examples",
      "mod.ts"
    ]
  },
  "imports": {
    "$errors": "./src/errors.ts",
    "$fmt": "./src/format.ts",
    "$types": "./src/types.ts",
    "$list": "./src/list/mod.ts",
    "$opts": "./src/opts/mod.ts",
    "$io": "./src/io/mod.ts",
    "$prompt": "./src/prompt/mod.ts",
    "@epdoc/terminal": "jsr:@epdoc/terminal@^0.0.14",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "@std/fmt": "jsr:@std/fmt@^1.0.10",
    "@std/io": "jsr:@std/io@^0.225.3"
  }
}
